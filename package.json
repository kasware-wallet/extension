{
  "name": "kasware-extension",
  "version": "0.8.50.3",
  "private": true,
  "homepage": "https://github.com/kasware-wallet/extension#readme",
  "workspaces": [
    "packages/*"
  ],
  "bugs": {
    "url": "https://github.com/kasware-wallet/extension/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kasware-wallet/extension.git"
  },
  "scripts": {
    "clean": "mkdir -p dist && rm -rf dist/* && cp -r build/_raw/* dist",
    "build:chrome:dev": "webpack --progress --env browser=chrome manifest=mv2 config=dev version=0.0.0",
    "build:chrome": "gulp build --env=pro --browser=chrome --manifest=mv2",
    "build:firefox": "cross-env manifest=mv2 gulp build --env=pro --browser=firefox --manifest=mv2",
    "build:firefox:dev": "webpack --progress --env browser=firefox manifest=mv2 config=dev version=0.0.0",
    "build:brave": "gulp build --env=pro --browser=brave --manifest=mv2",
    "build:edge": "gulp build --env=pro --browser=edge --manifest=mv2",
    "build:chrome:mv3:dev": "yarn install && webpack --progress --env browser=chrome manifest=mv3 config=dev",
    "build:chrome:mv3:pro": "yarn install && webpack --progress --env browser=chrome manifest=mv3 config=pro",
    "build:chrome:mv3": "yarn install && gulp build --env=pro --browser=chrome --manifest=mv3",
    "translate": "node build/pull_translation",
    "lint": "eslint src --fix --ext .js,.ts,.tsx,.json  && npm run format",
    "lint:fix": "eslint --fix src/**/*.{js,jsx,ts,tsx,json}",
    "_prettier": "prettier --write .",
    "fix:modules": "node scripts/fix-modules.js",
    "test": "jest unit",
    "playwright:headless": "PLAYWRIGHT_HEADLESS=false playwright test --project=chromium ",
    "playwright": "playwright test --project=chromium ",
    "format": "prettier --write \"src/**/*.{js,jsx,json,md,ts,tsx}\"",
    "prepare": "husky install",
    "build": "yarn workspaces run build"
  },
